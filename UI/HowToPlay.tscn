alignment = 1

[node name="SpinForce" type="TextureRect" parent="TextureRect/MarginContainer/The Beast/Pages/Page1/HBoxContainer2" unique_id=494758756]
custom_minimum_size = Vector2(288, 96)
custom_maximum_size = Vector2(288, 96)
layout_mode = 2
size_flags_horizontal = 0
size_flags_vertical = 4
texture = ExtResource("4_va4iu")

[node name="Paragraph3" type="RichTextLabel" parent="TextureRect/MarginContainer/The Beast/Pages/Page1/HBoxContainer2" unique_id=1510383761]
custom_minimum_size = Vector2(960, 280)
custom_maximum_size = Vector2(960, 280)
layout_mode = 2
theme_override_font_sizes/normal_font_size = 32
bbcode_enabled = true
text = "But, let's not worry about that. Instead, let me tell you how to run this machine. The first thing you need to understand is this meter here. That's your Spin Force, and it's the most important part about this machine. The higher the meter, the more candy you'll be able to produce every second and the faster you'll be able to move, so you best try and keep that as high as you can."
horizontal_alignment = 1

[node name="Page2" type="VBoxContainer" parent="TextureRect/MarginContainer/The Beast/Pages" unique_id=1503145518]
visible = false
layout_mode = 2
theme_override_constants/separation = 16
alignment = 1
metadata/_tab_index = 1
metadata/_tab_name = ""

[node name="Paragraph4" type="RichTextLabel" parent="TextureRect/MarginContainer/The Beast/Pages/Page2" unique_id=1312704630]
custom_minimum_size = Vector2(960, 188)
custom_maximum_size = Vector2(960, 188)
layout_mode = 2
theme_override_font_sizes/normal_font_size = 32
bbcode_enabled = true
text = "Unfortunately, friction still exists, so your Spin Force will always be gradually going down every few seconds, but don't worry. If you manage to get us some candy, we got some fixes for ya to help improve your machine. Anyways, I'm getting ahead of myself, we haven't even got to the arena yet! So, your Spin Force is always going down and we don't want that, right?"
horizontal_alignment = 1

[node name="HBoxContainer" type="HBoxContainer" parent="TextureRect/MarginContainer/The Beast/Pages/Page2" unique_id=1079605950]
layout_mode = 2
theme_override_constants/separation = 0

[node name="Paragraph5" type="RichTextLabel" parent="TextureRect/MarginContainer/The Beast/Pages/Page2/HBoxContainer" unique_id=221275769]
custom_minimum_size = Vector2(760, 370)
custom_maximum_size = Vector2(760, 370)
layout_mode = 2
theme_override_font_sizes/normal_font_size = 32
bbcode_enabled = true
text = "Well, that's where this next meter comes in. That's your Dash Battery. It shows you how much energy you have to execute a Dash, a fast moving strike that allows you to ram into your opponents at high speeds. To perform a Dash, you simply click on your machine and drag in the opposite direction of where you wanna go and watch as you zip across the map. What does any of this have to do with your Spin Force, you might ask? Well, the Dash is what's going to allow you to steal the Spin Force of your opponents by ramming into them and recharging your meter to keep yourself spinning!"
horizontal_alignment = 1

