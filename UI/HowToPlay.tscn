[node name="Paragraph1" type="RichTextLabel" parent="TextureRect/MarginContainer/The Beast/Pages/Page1" unique_id=1248113717]
custom_minimum_size = Vector2(960, 96)
custom_maximum_size = Vector2(960, 96)
layout_mode = 2
theme_override_font_sizes/normal_font_size = 32
bbcode_enabled = true
text = "So you wanna be a part of the revolution, do ya? Well, come on over and let me give you the low-down on our operations here. In this arena, there's only one thing that really matters: Cotton Candy."
horizontal_alignment = 1

[node name="HBoxContainer" type="HBoxContainer" parent="TextureRect/MarginContainer/The Beast/Pages/Page1" unique_id=1678739203]
layout_mode = 2
theme_override_constants/separation = 0
alignment = 1

[node name="Paragraph2" type="RichTextLabel" parent="TextureRect/MarginContainer/The Beast/Pages/Page1/HBoxContainer" unique_id=1856639142]
custom_minimum_size = Vector2(760, 220)
custom_maximum_size = Vector2(760, 220)
layout_mode = 2
theme_override_font_sizes/normal_font_size = 32
bbcode_enabled = true
text = "Yep, you heard that right, Cotton Candy. The most deadly, most aggressive, and down right most delicious Cotton Candy you'll ever get to taste. And there's only one way to get that here: The C-C-S-950! With this wonderful machine, you get to spin as much Cotton Candy as you want! ...That is, assuming you don't mind a little competition, and let me tell ya, they ain't no joke."
horizontal_alignment = 1

[node name="Spinner" type="TextureRect" parent="TextureRect/MarginContainer/The Beast/Pages/Page1/HBoxContainer" unique_id=1312832950]
