texture = ExtResource("6_j06ch")

[node name="Paragraph5" type="RichTextLabel" parent="TextureRect/MarginContainer/The Beast/Pages/Page3/HBoxContainer" unique_id=691573063]
custom_minimum_size = Vector2(800, 400)
custom_maximum_size = Vector2(800, 400)
layout_mode = 2
theme_override_font_sizes/normal_font_size = 32
bbcode_enabled = true
text = "Now hold on though, it's not quite that simple. See, the name of the game here is speed. If you're not faster than your opponent when you make contact, it's not gonna go well for ya. Starting out, ya might not want to face your opponents head on. Your best bet will be to try and find an opening when your opponent is slowing down and strike when the moment is right! And if you manage to take their Spin Force to zero in the process, you'll get an extra boost on top of it! But, if you're dead set on head-to-head collisions, well... I hear if you time your shots just right, you can reflect all of that damage back onto your opponent and turn the tables, so keep that in mind."
horizontal_alignment = 1

[node name="Paragraph6" type="RichTextLabel" parent="TextureRect/MarginContainer/The Beast/Pages/Page3" unique_id=11970955]
custom_minimum_size = Vector2(960, 250)
custom_maximum_size = Vector2(960, 250)
layout_mode = 2
theme_override_font_sizes/normal_font_size = 32
bbcode_enabled = true
text = "Alright, that's everything you need to know! Oh, and don't worry if your Spin Force gets depleted. It's not game over, you'll be taken out of the arena to go recharge and get your bearings before getting right back into the thick of it! And every time a round is over, you can take the candy you produced over to our Upgrades Shop to trade it in for some better gear to make your time in the Arena even better! So what are you waiting for? Get out there and start making some Cotton Candy!"
horizontal_alignment = 1

