[node name="Paragraph5" type="RichTextLabel" parent="TextureRect/MarginContainer/The Beast/Pages/Page3/HBoxContainer" unique_id=691573063]
custom_minimum_size = Vector2(800, 400)
custom_maximum_size = Vector2(800, 400)
layout_mode = 2
theme_override_font_sizes/normal_font_size = 32
bbcode_enabled = true
text = "Now hold on though, it's not quite that simple. [wave amp=10.0 freq=3.0 connected=1][outline_color=0d2030]See, the name of the game here is speed[/outline_color][/wave]. If you're not faster than your opponent when you make contact, it's not gonna go well for ya. Starting out, ya might not want to face your opponents head on. [wave amp=8.0 freq=2.0 connected=1][outline_color=0d2030]Your best bet will be to try and find an opening when your opponent is slowing down and strike when the moment is right![/outline_color][/wave] And if you manage to take their [color=cf3c71][outline_color=5a1991]Spin Force[/outline_color][/color] to zero in the process, you'll get an extra boost on top of it! But, if you're dead set on head-to-head collisions, well... [wave amp=8.0 freq=2.0 connected=1][outline_color=0d2030]I hear if you time your shots just right, you can [wave amp=12.0 freq=4.0 connected=1][color=98dcff]parry[/color][/wave] all that damage coming your way to buy you a couple more seconds, so keep that in mind."
horizontal_alignment = 1

[node name="Paragraph6" type="RichTextLabel" parent="TextureRect/MarginContainer/The Beast/Pages/Page3" unique_id=11970955]
custom_minimum_size = Vector2(960, 250)
custom_maximum_size = Vector2(960, 250)
layout_mode = 2
theme_override_font_sizes/normal_font_size = 32
bbcode_enabled = true
text = "Alright, that's everything you need to know! Oh, and don't worry if your [color=cf3c71][outline_color=5a1991]Spin Force[/outline_color][/color] gets depleted. [wave amp=8.0 freq=2.0 connected=1][outline_color=0d2030]It's not game over, you'll be taken out of the arena to go recharge and get your bearings before getting right back into the thick of it! And every time a round is over, you can take the candy you produced over to our Upgrades Shop to trade it in for some better gear to make your time in the Arena even better![/outline_color][/wave] So what are you waiting for? Get out there and start making some  [shake rate=24.0 level=11 connected=1][color=fec9ed][outline_color=cf3c71]Cotton Candy!"
horizontal_alignment = 1

