[node name="TextureRect" type="TextureRect" parent="TextureRect/MarginContainer/The Beast/Pages/Page3/HBoxContainer" unique_id=866333182]
custom_minimum_size = Vector2(200, 160)
custom_maximum_size = Vector2(200, 160)
layout_mode = 2
